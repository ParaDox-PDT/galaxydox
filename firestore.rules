rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read-only access to planets collection (3D model URLs)
    match /planets/{planetId} {
      allow read: if true;
      allow write: if false;
    }

    // Public read-only access to wallpapers collection
    match /wallpapers/{wallpaperId} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all access to any other collection
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
